# =============================================
# StudioSync Backend — Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/studiosync
# OR use MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/studiosync?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d     # token lifetime, e.g. 1h, 7d, 30d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5174

# Email (Nodemailer — S2-08)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password   # Use an App Password, not your real password
